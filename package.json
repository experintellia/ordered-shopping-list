{
  "name": "grocery-board",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host --port 3000",
    "start": "vite --host --port 3000",
    "build": "tsc && vite build",
    "preview": "vite preview --host",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:peers": "concurrently \"npm run dev\" \"webxdc-dev run http://localhost:3000\"",
    "fix": "prettier --write .",
    "check": "prettier --check ."
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-draggable": "^4.7.0",
    "y-webxdc": "^1.2.0",
    "yjs": "^13.6.31"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^6.0.3",
    "@webxdc/types": "latest",
    "@webxdc/vite-plugins": "^2.0.0",
    "@webxdc/webxdc-dev": "latest",
    "concurrently": "latest",
    "happy-dom": "^20.10.6",
    "prettier": "latest",
    "typescript": "latest",
    "vite": "latest",
    "vitest": "latest"
  },
  "version": "0.1.0"
}
